# Connection pooled (usa esta en runtime — la app la usa en cada request).
# En Neon: Connection Details → activa "Pooled connection". Agrega &pgbouncer=true al final.
DATABASE_URL="postgresql://user:password@host-pooler/dbname?sslmode=require&pgbouncer=true"

# Connection directa, sin pool (solo para `prisma db push` / `prisma migrate`).
# En Neon: la misma Connection Details, pero con "Pooled connection" desactivado.
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# genera uno con: openssl rand -base64 32
AUTH_SECRET="reemplaza-esto-con-un-secreto-aleatorio"
